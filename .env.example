# Copie para .env e preencha. NÃO comitar .env.
SCRAPECREATORS_API_KEY=
# Só necessário com --llm (Nível 2, Haiku via Batch API):
ANTHROPIC_API_KEY=
# Opcional: sobrescreve pricing.credit_usd do yaml
CREDIT_USD=0.002
# Opcional: sobrescreve pricing.model_tier2 do yaml
MODEL_TIER2=claude-haiku-4-5
# Fase 1 — banco. Local sem docker cai em SQLite. Com docker-compose:
# DATABASE_URL=postgresql+psycopg://miner:miner@localhost:5432/tiktok_miner
# No Railway: use a var DATABASE_URL do plugin Postgres (postgres:// é normalizado).
DATABASE_URL=
# Fase 3 — CORS do frontend (Vercel). Em prod: https://seu-app.vercel.app
CORS_ORIGINS=*
# Railway: semeia o DB de keywords no 1º boot da API.
AUTO_SEED=
# Token que protege o disparo de varredura pelo dashboard (senão qualquer um torra crédito).
# Gere um valor forte e coloque o MESMO no frontend (o operador informa no dash).
TRIGGER_TOKEN=
